{
  "name": "pse-vision-worker",
  "private": true,
  "version": "1.0.0",
  "description": "PSE Vision Worker Display - Desktop App for factory workers",
  "author": "PSE Vision Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "desktop": "npm run build && electron .",
    "prebuild:frontend": "node scripts/prebuild.cjs",
    "dist": "npm run prebuild:frontend && npm run build && electron-builder",
    "dist:win": "npm run prebuild:frontend && npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.pse.vision.worker",
    "productName": "PSE Vision Worker Display",
    "copyright": "Copyright © 2026 PSE Vision Project",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../python_embedded",
        "to": "python_embedded",
        "filter": [
          "**/*",
          "!python-embed.zip",
          "!get-pip.py"
        ]
      },
      {
        "from": "../python_scripts",
        "to": "python_scripts",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/node_modules",
          "!dist",
          "!build",
          "!backend_server.spec"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../config/database/db_config.json",
        "to": "config/database/db_config.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/Logo_checksize.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PSE Vision Worker",
      "installerIcon": "public/Logo_checksize.ico",
      "uninstallerIcon": "public/Logo_checksize.ico",
      "installerHeaderIcon": "public/Logo_checksize.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "uninstallDisplayName": "PSE Vision Worker Display",
      "warningsAsErrors": false
    },
    "compression": "maximum",
    "removePackageScripts": true
  }
}
